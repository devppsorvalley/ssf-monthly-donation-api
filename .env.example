# Razorpay credentials
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Required for admin-only endpoints such as /api/subscriptions/plan and /api/subscriptions/payment-page
ADMIN_TOKEN=replace_with_a_long_random_secret

# Optional: create a reusable plan once and reuse the plan ID
# If blank, you can create a plan via /api/subscriptions/plan
RAZORPAY_PLAN_ID=

# Razorpay webhook secret for secure webhook verification
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Shared subscription settings for the reusable donor page
SUBSCRIPTION_INTERVAL=monthly
SUBSCRIPTION_INTERVAL_COUNT=1
SUBSCRIPTION_TOTAL_COUNT=24
SUBSCRIPTION_AMOUNT=10000
SUBSCRIPTION_CURRENCY=INR
SUBSCRIPTION_DESCRIPTION=SSF Monthly Donation

# Public donation API limits, in paise
MIN_DONATION_AMOUNT=10000
MAX_DONATION_AMOUNT=10000000
MAX_SUBSCRIPTION_TOTAL_COUNT=120

# Optional Google Sheets sync after successful subscription checkout
GOOGLE_SHEETS_ID=your_google_sheet_id
GOOGLE_SHEETS_RANGE=Donations!A:O
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"

# Server port (optional, defaults to 4000)
PORT=4000
