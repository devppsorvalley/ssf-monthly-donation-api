# Razorpay credentials
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Optional: create a reusable plan once and reuse the plan ID in /public/subscription.html
# If blank, you can create a plan via /api/subscriptions/plan
RAZORPAY_PLAN_ID=

# Razorpay webhook secret for secure webhook verification
RAZORPAY_WEBHOOK_SECRET=

# Shared subscription settings for the reusable donor page
SUBSCRIPTION_INTERVAL=monthly
SUBSCRIPTION_INTERVAL_COUNT=1
SUBSCRIPTION_TOTAL_COUNT=12
SUBSCRIPTION_AMOUNT=10000
SUBSCRIPTION_CURRENCY=INR
SUBSCRIPTION_DESCRIPTION=SSF Monthly Donation
